# Sample env for running a replay by hand, the same stack the test harness runs:
#
#   Lean (eval image in isolation — replay stubs the gateway):
#     docker compose -f containers/benchmarks/aime/compose.yaml \
#                    -f tests/run/replay/replay-lean.yaml \
#                    --env-file tests/run/replay/replay.env.example up --abort-on-container-exit
#
#   Full-stack (real gateway + otelcol, replay as the upstream): swap the overlay
#   for replay-upstream.yaml and set OPENAI_API_BASE=http://upstream:4000 plus a
#   real EVAL_MODEL handle (e.g. openai/azure/gpt-5.4).
#
# Then read output/<benchmark>/<task>/task/result.json (and, full-stack, traces.jsonl).

# Which eval image to run.
EVAL_BENCHMARK=aime
EVAL_AGENT=claude-code
EVAL_TASK_ID=0

# Registry the images live under (ghcr.io/exgentic for published, localhost/ec for a local classic build).
EVAL_REGISTRY=ghcr.io/exgentic

# Per-run replay wiring (both overlays read these).
REPLAY_FIXTURE=./tests/run/replay/fixtures/aime-0-claude-code.traces.jsonl
REPLAY_OUTPUT=./output/aime/0

# Lean: replay ignores the model; a placeholder satisfies compose interpolation.
EVAL_MODEL=replay
EVAL_GATEWAY_LABEL=replay
OPENAI_API_KEY=sk-replay
OPENAI_API_BASE=https://replay.invalid
