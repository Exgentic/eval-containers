{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "openai": {
      "keys": [
        { "name": "default", "value": "env.OPENAI_API_KEY", "models": ["*"], "weight": 1.0 }
      ],
      "network_config": { "base_url": "${OPENAI_API_BASE}" }
    },
    "anthropic": {
      "keys": [
        { "name": "default", "value": "env.OPENAI_API_KEY", "models": ["*"], "weight": 1.0 }
      ],
      "network_config": { "base_url": "${OPENAI_API_BASE}" }
    },
    "gemini": {
      "keys": [
        { "name": "default", "value": "env.OPENAI_API_KEY", "models": ["*"], "weight": 1.0 }
      ],
      "network_config": { "base_url": "${OPENAI_API_BASE}" }
    }
  },
  "governance": {
    "routing_rules": [
      {
        "id": "rewrite-to-upstream",
        "name": "rewrite-to-upstream",
        "enabled": true,
        "cel_expression": "true",
        "scope": "global",
        "targets": [
          { "provider": "${PROVIDER}", "model": "${MODEL_NAME}", "weight": 1.0 }
        ]
      }
    ]
  }
}
