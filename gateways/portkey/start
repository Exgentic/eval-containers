#!/bin/sh
# Start Caddy (:4000) + Portkey (:8787) + Bifrost (:4002).
#
# Routes (set in Caddyfile):
#   /openai/*    → portkey (with x-portkey-config model rewrite)
#   /anthropic/* → bifrost  (Anthropic → OpenAI Chat → upstream)
#   /genai/*     → bifrost  (Google    → OpenAI Chat → upstream)
#
# Env contract:
#   EVAL_MODEL        <provider>/<model> for the routing target.
#
# Upstream auth flows through whatever env vars the chosen provider's
# SDK reads (OPENAI_API_KEY + OPENAI_API_BASE for OpenAI-compatible
# endpoints; ANTHROPIC_API_KEY, AWS_*, GOOGLE_* for direct providers).
# Portkey receives the key via x-portkey-config; bifrost reads it from
# env. The framework does NOT introduce a `EVAL_API_*` umbrella alias.

set -eu

: "${EVAL_MODEL:?EVAL_MODEL must be set to <provider>/<model>}"

case "$EVAL_MODEL" in
  */*)
    PROVIDER=${EVAL_MODEL%%/*}
    MODEL_NAME=${EVAL_MODEL#*/}
    ;;
  *)
    echo "EVAL_MODEL must be of form <provider>/<model> (got: $EVAL_MODEL)" >&2
    exit 2
    ;;
esac

# Portkey wants custom-host with /v1 suffix; it appends /chat/completions, etc.
case "${OPENAI_API_BASE:-}" in
  */v1|*/v1/) CUSTOM_HOST="${OPENAI_API_BASE%/}" ;;
  ?*)         CUSTOM_HOST="${OPENAI_API_BASE%/}/v1" ;;
  *)          CUSTOM_HOST="" ;;
esac

# x-portkey-config: full routing config (provider + api_key +
# override_params.model). Portkey requires one of {provider+api_key,
# strategy+targets, cache, retry} at the top level — the first form is
# simplest. override_params rewrites whatever model the agent sends
# to the configured upstream model.
PORTKEY_CONFIG=$(printf '{"provider":"openai","api_key":"%s","override_params":{"model":"%s"}}' \
  "${OPENAI_API_KEY:-}" "$MODEL_NAME")

export PROVIDER MODEL_NAME CUSTOM_HOST PORTKEY_CONFIG

# Bifrost sidecar config (used for /anthropic and /genai translation).
envsubst '${PROVIDER} ${MODEL_NAME} ${OPENAI_API_BASE}' \
  < /opt/gateway/bifrost/config.json.template \
  > /opt/gateway/bifrost/data/config.json

# Bifrost on 127.0.0.1:4002.
/opt/gateway/bifrost/main \
  -app-dir /opt/gateway/bifrost/data \
  -port 4002 \
  -host 127.0.0.1 \
  -log-level "${LOG_LEVEL:-warn}" \
  -log-style json &

# Caddy on $PORT (default 4000).
caddy run --config /opt/gateway/Caddyfile --adapter caddyfile &

# Portkey bound to 127.0.0.1:8787 (foreground; container PID 1).
cd /opt/gateway/portkey
exec node build/start-server.js
