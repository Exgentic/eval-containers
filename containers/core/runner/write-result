#!/bin/bash
# Final result writer. Runs after the verifier completes.
#
# Reads:
#   /logs/verifier/reward.txt   written by /grade.sh
#   /output/agent/.started-at   written by /usr/local/bin/run
#
# Writes:
#   /output/task/result.json    task_id, benchmark, reward, passed
#   /output/agent/result.json   agent, started_at, ended_at
#   /output/model/result.json   model
set -euo pipefail

# The verifier may not produce a numeric reward (e.g. the agent errored or
# exhausted its recorded replay turns before grading). Coerce anything missing,
# empty, or non-numeric to 0 so result.json is ALWAYS valid JSON — the `%s`
# reward below sits in a JSON number slot, so a stray token would break parsing.
REWARD=$(head -1 /logs/verifier/reward.txt 2>/dev/null | tr -d '[:space:]' || true)
[[ "$REWARD" =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || REWARD=0
PASSED=$(awk -v r="$REWARD" 'BEGIN{print (r+0 >= 1) ? "true" : "false"}')
ENDED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
STARTED_AT=$(cat /output/agent/.started-at 2>/dev/null || echo "$ENDED_AT")

printf '{"task_id":"%s","benchmark":"%s","reward":%s,"passed":%s}\n' \
  "${TASK_ID:-unknown}" "${BENCHMARK:-unknown}" "$REWARD" "$PASSED" \
  > /output/task/result.json

printf '{"agent":"%s","started_at":"%s","ended_at":"%s"}\n' \
  "${AGENT:-unknown}" "$STARTED_AT" "$ENDED_AT" \
  > /output/agent/result.json

printf '{"model":"%s"}\n' "${MODEL:-unknown}" > /output/model/result.json
