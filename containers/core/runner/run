#!/bin/bash
# Eval entrypoint — preps env/dirs/output, then drives the three-phase eval
# (agent → verifier → result, benchmarks/RULES.md rule 12).
#
# Two execution paths, selected by whether the caller pre-set ANTHROPIC_BASE_URL:
#
#   set (compose / k8s "runner" mode)  → the lean eval base.
#       otelcol + gateway are sibling containers/pods the orchestrator already
#       started and health-gated, so by the time this container runs the agent
#       can reach them immediately. There is nothing to orchestrate in-container:
#       the three phases run as a plain shell sequence — no process-compose.
#
#   unset (single-container mode)      → the -standalone bundle.
#       otelcol + gateway run in-process, so process-compose brings up all five
#       units (otelcol → gateway → agent → verifier → result) with readiness
#       gating. process-compose + /etc/process-compose.yaml ship ONLY in the
#       bundle (core/standalone.Dockerfile); the lean base has neither.
#
# Same agent/verifier/result semantics in both paths; the agent launch itself is
# shared via /usr/local/bin/run-agent so rule 7's env allow-list has one home.
#
# Env-var contract (set by /entrypoint.sh wrapper / the orchestrator):
#   TASK              agent's task prompt
#   EXPECTED_ANSWER   verifier's ground truth (NOT visible to agent)
#   TASK_ID           task identifier (verifier/result only — never the agent)
#   BENCHMARK         benchmark name (for result.json)
#   AGENT             agent name (for result.json)
#   MODEL             model name (for result.json)
#   TIMEOUT           agent wall-clock timeout in seconds
#   OPENAI_API_KEY    read by the in-container gateway in single-container mode
set -euo pipefail

# Resolve from the EVAL_* canonical axis first (what the CLI sets in container
# mode), falling back to the bare legacy names (set by compose/k8s), then a
# default. run-agent reads these from the env it inherits.
export TIMEOUT="${TIMEOUT:-${EVAL_TIMEOUT:-300}}"
export TASK_ID="${TASK_ID:-${EVAL_TASK_ID:-}}"
export MODEL="${MODEL:-${EVAL_MODEL:-}}"
export BENCHMARK="${BENCHMARK:-${EVAL_BENCHMARK:-unknown}}"
export AGENT="${AGENT:-${EVAL_AGENT:-unknown}}"
export TASK="${TASK:-}"

# Defensive fallback (agent uid baked into image at build time).
id agent &>/dev/null || useradd -m -s /bin/bash -u 1002 agent

# Output dirs.
mkdir -p /output/{model,agent,task} /logs/verifier
chown -R agent:agent /output/agent /tmp 2>/dev/null || true
chmod 0755 /output /output/agent /output/task /output/model

# Capture run start time for the result writer.
date -u +%Y-%m-%dT%H:%M:%SZ > /output/agent/.started-at

# ─── Runner mode (lean base) ──────────────────────────────────────────
# External gateway iff ANTHROPIC_BASE_URL was set by the caller. The gateway +
# otelcol are siblings the orchestrator health-gated, so run the three phases
# directly. Each phase runs regardless of the previous one's exit status
# (process-compose's `process_completed` semantics): the verifier always grades
# whatever the agent produced — even on a timeout or crash — and a result.json
# is always written.
if [ -n "${ANTHROPIC_BASE_URL+set}" ]; then
  /usr/local/bin/run-agent || true
  bash /grade.sh || true
  exec /usr/local/bin/write-result
fi

# ─── Single-container mode (bundle) ───────────────────────────────────
# We own the whole pipeline. Point the agent + gateway at loopback and let
# process-compose bring up otelcol → gateway → agent → verifier → result.
export ANTHROPIC_BASE_URL="http://127.0.0.1:4000/anthropic"
# OpenAI base needs /v1 (clients append /chat/completions); anthropic doesn't.
export OPENAI_BASE_URL="${OPENAI_BASE_URL:-http://127.0.0.1:4000/openai/v1}"
export GOOGLE_GEMINI_BASE_URL="${GOOGLE_GEMINI_BASE_URL:-http://127.0.0.1:4000/genai}"
# litellm's OTel callback honors this env var; bifrost reads its collector_url
# from config.json. Setting it unconditionally is harmless for bifrost.
export OTEL_EXPORTER_OTLP_ENDPOINT="${OTEL_EXPORTER_OTLP_ENDPOINT:-http://otelcol:4318}"

# The gateway config hardcodes the hostname `otelcol`; in-process there is no
# DNS, so map it to loopback (only when nothing else already resolves it).
if ! getent hosts otelcol >/dev/null 2>&1; then
  echo "127.0.0.1 otelcol" >> /etc/hosts
fi

exec /usr/local/bin/process-compose up \
  --config /etc/process-compose.yaml \
  --disable-dotenv \
  --tui=false
