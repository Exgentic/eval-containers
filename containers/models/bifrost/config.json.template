{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "evalupstream": {
      "keys": [
        { "name": "default", "value": "env.OPENAI_API_KEY", "models": ["*"], "weight": 1.0 }
      ],
      "network_config": { "base_url": "${OPENAI_API_BASE}", "allow_private_network": true },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true,
          "responses": true,
          "responses_stream": true,
          "text_completion": true,
          "text_completion_stream": true,
          "count_tokens": true
        }
      }
    }
  },
  "governance": {
    "routing_rules": [
      {
        "id": "rewrite-to-upstream",
        "name": "rewrite-to-upstream",
        "enabled": true,
        "cel_expression": "true",
        "scope": "global",
        "targets": [
          { "provider": "evalupstream", "model": "${MODEL_NAME}", "weight": 1.0 }
        ]
      }
    ]
  },
  "plugins": [
    {
      "enabled": true,
      "name": "otel",
      "config": {
        "service_name": "dock-gateway",
        "collector_url": "${OTEL_COLLECTOR_URL}",
        "trace_type": "genai_extension",
        "protocol": "http"
      }
    }
  ],
  "framework": {
    "pricing": {
      "pricing_url": "file:///opt/gateway/data/pricing.json",
      "model_parameters_url": "file:///opt/gateway/data/model-parameters.json",
      "mcp_library_url": "file:///opt/gateway/data/mcp-library.json",
      "pricing_sync_interval": 86400,
      "mcp_library_sync_interval": 86400
    }
  }
}
