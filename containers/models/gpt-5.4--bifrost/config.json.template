{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "openai": {
      "keys": [
        { "name": "default", "value": "env.OPENAI_API_KEY", "models": ["*"], "weight": 1.0 }
      ],
      "network_config": { "base_url": "${OPENAI_API_BASE}" }
    },
    "anthropic": {
      "keys": [
        { "name": "default", "value": "env.OPENAI_API_KEY", "models": ["*"], "weight": 1.0 }
      ],
      "network_config": { "base_url": "${OPENAI_API_BASE}" }
    },
    "gemini": {
      "keys": [
        { "name": "default", "value": "env.OPENAI_API_KEY", "models": ["*"], "weight": 1.0 }
      ],
      "network_config": { "base_url": "${OPENAI_API_BASE}" }
    }
  },
  "governance": {
    "budgets": [
      { "id": "eval-budget", "max_limit": ${EVAL_MODEL_MAX_BUDGET}, "reset_duration": "1Y" }
    ],
    "virtual_keys": [
      { "id": "eval-vk", "value": "sk-proxy", "is_active": true, "budget_id": "eval-budget" }
    ],
    "pricing_overrides": [
      {
        "id": "eval-pricing",
        "scope_kind": "global",
        "match_type": "wildcard",
        "pattern": "*",
        "request_types": ["chat_completion"],
        "pricing_patch": "{\"input_cost_per_token\":0.0000025,\"output_cost_per_token\":0.000010}"
      }
    ],
    "routing_rules": [
      {
        "id": "rewrite-to-upstream",
        "name": "rewrite-to-upstream",
        "enabled": true,
        "cel_expression": "true",
        "scope": "global",
        "targets": [
          { "provider": "${PROVIDER}", "model": "${MODEL_NAME}", "weight": 1.0 }
        ]
      }
    ]
  },
  "plugins": [
    { "enabled": true, "name": "governance", "config": { "is_vk_mandatory": true } },
    {
      "enabled": true,
      "name": "otel",
      "config": {
        "service_name": "dock-gateway",
        "collector_url": "${OTEL_COLLECTOR_URL}",
        "trace_type": "genai_extension",
        "protocol": "http"
      }
    }
  ]
}
