#!/bin/bash
# Single-image orchestrator. Reached only from eval-entrypoint.sh when no
# external gateway was wired (ANTHROPIC_BASE_URL unset). Points the base URLs
# at the in-container gateway on loopback — so the runner's eval-entrypoint
# talks to it instead of branching back here — then hands off to
# process-compose, which runs otelcol + gateway + runner (/entrypoint.sh).
set -euo pipefail

# In-container services live on loopback.
export ANTHROPIC_BASE_URL="http://127.0.0.1:4000/anthropic"
export OPENAI_BASE_URL="http://127.0.0.1:4000/openai"
# The gateway config hardcodes the hostname `otelcol` (so the same config
# works in compose mode under docker DNS); resolve it to loopback here, and
# point litellm's OTel callback at it too.
if ! getent hosts otelcol >/dev/null 2>&1; then
  echo "127.0.0.1 otelcol" >> /etc/hosts
fi
export OTEL_EXPORTER_OTLP_ENDPOINT="${OTEL_EXPORTER_OTLP_ENDPOINT:-http://otelcol:4318}"

# Defensive fallback (agent uid baked into image at build time).
id agent &>/dev/null || useradd -m -s /bin/bash -u 1002 agent

mkdir -p /output/{model,agent,task} /logs/verifier

exec /usr/local/bin/process-compose up \
  --config /etc/process-compose.yaml \
  --disable-dotenv \
  --tui=false
