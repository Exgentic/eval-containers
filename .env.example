# Dock configuration
# Copy to .env and fill in your values:  cp .env.example .env

# Required: at least one API key for the model you're using
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Registry: where images and compose files are stored
# Default: ghcr.io/dock-eval (production)
# For local development: localhost:5000
DOCK_REGISTRY=ghcr.io/dock-eval

# Default agent and model (can be overridden per run)
DOCK_AGENT=claude-code
DOCK_MODEL=claude-sonnet-4

# Default timeout in seconds (can be overridden per run or per benchmark)
DOCK_TIMEOUT=300
